# MySQL 数据库配置
DB_HOST=localhost
DB_PORT=3306
DB_USERNAME=root
DB_PASSWORD=your_mysql_password
DB_DATABASE=campus_management

# JWT 配置
JWT_SECRET=your-jwt-secret-key
JWT_EXPIRES_IN=7200

# AI 配置（可选，不配置则 AI 助手显示提示信息）
AI_PROVIDER=deepseek
AI_API_KEY=
AI_MODEL=deepseek-chat
AI_MAX_TOKENS=4096
# AI_BASE_URL=https://api.deepseek.com/v1

# 服务端口
PORT=3000
